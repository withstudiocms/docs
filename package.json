  "__pnpmOverridesNote": "This is a version fix to lock all installations of vite to the same version, as it is a peer dependency of many of the packages we use.",
  "pnpm": {
    "overrides": {
      "vite": "^6.3.4"
    },
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@parcel/watcher",
      "canvas",
      "esbuild",
      "msgpackr-extract",
      "oxc-resolver",
      "sharp"
    ]
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2"
  }
