---
import { makeHtmlComponent } from 'effectify/scalar';

type Source = Parameters<typeof makeHtmlComponent>[0]['sources'][number];

interface Props {
	source: Source;
}

const { source } = Astro.props;

const html = makeHtmlComponent({
	starlight: true,
	scalar: {
		baseServerURL: 'http://localhost:4321',
		hideTestRequestButton: true,
		hideSearch: true,
		layout: 'classic',
		hideDarkModeToggle: true,
	},
	sources: [source],
});
---
<Fragment set:html={html} />

<style is:global>
	.not-content {
		margin-top: 0;
	}
	.references-classic-header-container {
		display: none;
	}
	.references-classic {
		.section.introduction-section {
			margin-top: 0;
			padding-top: 0 !important;
		} 
	}
</style>